#!/bin/bash
set -u

readonly PLUGIN_ROOT="/usr/local/emhttp/plugins/usb.guardian"
readonly CONFIG_ROOT="/boot/config/plugins/usb.guardian"
readonly CONFIG_FILE="${CONFIG_ROOT}/usb.guardian.cfg"
readonly LOG_DIR="${CONFIG_ROOT}/logs"
readonly RUN_ROOT="/run/usb-guardian"
readonly JOB_DIR="${RUN_ROOT}/jobs"
readonly BINARY="${PLUGIN_ROOT}/bin/usb-guardian"
readonly DEFAULT_CONFIG="${PLUGIN_ROOT}/default.cfg"
readonly SERVICE_LOG="${LOG_DIR}/service.log"

boot_flash_is_safe() {
  local awk_bin
  awk_bin="$(command -v awk 2>/dev/null || true)"
  [[ -n "${awk_bin}" && -x "${awk_bin}" && -r /proc/self/mountinfo ]] || return 1
  "${awk_bin}" '
    {
      separator = 0
      for (i = 7; i <= NF; i++) if ($i == "-") { separator = i; break }
      if ($5 == "/boot") {
        count++
        fstype = $(separator + 1)
        source = $(separator + 2)
        if (separator > 0 && $4 == "/" && $6 ~ /(^|,)rw(,|$)/ &&
            (fstype == "vfat" || fstype == "msdos" || fstype == "fat") && source ~ /^\/dev\//) valid++
      }
      protected = "/boot/config/plugins/usb.guardian"
      if ($5 != "/boot" && (index(protected "/", $5 "/") == 1 || index($5 "/", protected "/") == 1)) shadow++
    }
    END { exit !(count == 1 && valid == 1 && shadow == 0) }
  ' /proc/self/mountinfo
}

rotate_service_log() {
  if [[ -f "${SERVICE_LOG}" ]] && (( $(/usr/bin/stat -c '%s' "${SERVICE_LOG}") >= 1048576 )); then
    /bin/rm -f -- "${SERVICE_LOG}.2"
    [[ ! -f "${SERVICE_LOG}.1" ]] || /bin/mv -f -- "${SERVICE_LOG}.1" "${SERVICE_LOG}.2"
    /bin/mv -f -- "${SERVICE_LOG}" "${SERVICE_LOG}.1"
  fi
}

if ! boot_flash_is_safe; then
  /usr/bin/logger -t usb.guardian "startup refused: /boot is not a single writable FAT block-device mount" 2>/dev/null || true
  exit 1
fi

/usr/bin/install -d -m 0700 "${CONFIG_ROOT}" "${LOG_DIR}" "${RUN_ROOT}" "${JOB_DIR}" "${RUN_ROOT}/diagnostics" "${RUN_ROOT}/ud-adapter"
if [[ ! -f "${CONFIG_FILE}" && -f "${DEFAULT_CONFIG}" ]]; then
  /usr/bin/install -m 0600 "${DEFAULT_CONFIG}" "${CONFIG_FILE}"
fi
rotate_service_log

if [[ ! -x "${BINARY}" ]]; then
  /usr/bin/logger -t usb.guardian "startup failed: core binary is missing or not executable"
  /usr/bin/printf '%s startup failed: core binary is missing or not executable\n' "$(/bin/date --iso-8601=seconds)" >> "${SERVICE_LOG}"
  exit 1
fi

{
  /usr/bin/printf '%s recovery start\n' "$(/bin/date --iso-8601=seconds)"
  "${BINARY}" recover --config "${CONFIG_FILE}" --job-dir "${JOB_DIR}" --log-dir "${LOG_DIR}"
  rc=$?
  /usr/bin/printf '%s recovery finish rc=%s\n' "$(/bin/date --iso-8601=seconds)" "${rc}"
  exit "${rc}"
} >> "${SERVICE_LOG}" 2>&1
