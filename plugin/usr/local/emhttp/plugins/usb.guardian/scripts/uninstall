#!/bin/bash
set -euo pipefail

readonly RUN_ROOT="/run/usb-guardian"
readonly ADAPTER_STATE_DIR="${RUN_ROOT}/ud-adapter"
readonly LOG_DIR="/boot/config/plugins/usb.guardian/logs"
readonly TRANSACTION_DIR="${LOG_DIR}/transactions"
readonly LOCK_FILE="${LOG_DIR}/.transaction.lock"

boot_flash_is_safe() {
  local awk_bin
  awk_bin="$(command -v awk 2>/dev/null || true)"
  [[ -n "${awk_bin}" && -x "${awk_bin}" && -r /proc/self/mountinfo ]] || return 1
  "${awk_bin}" '
    {
      separator = 0
      for (i = 7; i <= NF; i++) if ($i == "-") { separator = i; break }
      if ($5 == "/boot") {
        count++
        fstype = $(separator + 1)
        source = $(separator + 2)
        if (separator > 0 && $4 == "/" && $6 ~ /(^|,)rw(,|$)/ &&
            (fstype == "vfat" || fstype == "msdos" || fstype == "fat") && source ~ /^\/dev\//) valid++
      }
      protected = "/boot/config/plugins/usb.guardian"
      if ($5 != "/boot" && (index(protected "/", $5 "/") == 1 || index($5 "/", protected "/") == 1)) shadow++
    }
    END { exit !(count == 1 && valid == 1 && shadow == 0) }
  ' /proc/self/mountinfo
}

refuse_uninstall() {
  local message="$1"
  /usr/bin/logger -t usb.guardian "uninstall refused: ${message}" 2>/dev/null || true
  /usr/bin/printf 'USB Guardian cannot be uninstalled: %s\n' "${message}" >&2
  exit 1
}

assert_no_worker() {
  if /usr/bin/pgrep -f '^/usr/local/emhttp/plugins/usb[.]guardian/bin/usb-guardian eject ' >/dev/null 2>&1; then
    refuse_uninstall 'a safe-eject transaction is still running'
  fi
}

acquire_transaction_lock() {
  local flock_bin

  /usr/bin/install -d -m 0700 "${LOG_DIR}"
  flock_bin="$(command -v flock 2>/dev/null || true)"
  [[ -n "${flock_bin}" && -x "${flock_bin}" ]] || refuse_uninstall 'flock is unavailable, so transaction exclusion cannot be verified'

  exec 9>>"${LOCK_FILE}"
  if ! "${flock_bin}" -n 9; then
    refuse_uninstall 'the persistent transaction lock is busy'
  fi
}

assert_no_recovery_state() {
  local active_markers adapter_states adapter_artifacts

  shopt -s nullglob
  active_markers=("${TRANSACTION_DIR}"/*/active.json)
  adapter_states=("${ADAPTER_STATE_DIR}"/*.json)
  adapter_artifacts=("${ADAPTER_STATE_DIR}"/*)
  if (( ${#active_markers[@]} > 0 )); then
    refuse_uninstall 'an interrupted or active transaction marker still requires recovery'
  fi
  if (( ${#adapter_states[@]} > 0 )); then
    refuse_uninstall 'Unassigned Devices rollback state still requires recovery'
  fi
  if (( ${#adapter_artifacts[@]} > 0 )); then
    refuse_uninstall 'unrecognized adapter recovery artifacts are present'
  fi
}

remove_package() {
  if ! /sbin/removepkg usb.guardian; then
    refuse_uninstall 'the package manager could not remove usb.guardian'
  fi
}

remove_runtime_state() {
  local resolved_run_root

  if [[ -d "${RUN_ROOT}" ]]; then
    resolved_run_root="$(/usr/bin/readlink -f -- "${RUN_ROOT}")"
    [[ "${resolved_run_root}" == "${RUN_ROOT}" ]] || refuse_uninstall 'runtime directory identity is unexpected'
    /bin/rm -rf -- "${RUN_ROOT}"
  fi
}

uninstall_main() {
  local remove_installed_package=false

  if (( $# > 1 )); then
    refuse_uninstall 'unexpected arguments were supplied'
  fi
  if (( $# == 1 )); then
    [[ "$1" == '--remove-package' ]] || refuse_uninstall "unknown option: $1"
    remove_installed_package=true
  fi

  boot_flash_is_safe || refuse_uninstall '/boot is not a single writable FAT block-device mount'

  # This early check only improves the refusal message. All authority checks are repeated under FD 9.
  assert_no_worker
  acquire_transaction_lock
  assert_no_worker
  assert_no_recovery_state

  # In PLG removal mode, keep FD 9 locked while the executable is removed and runtime state is cleared.
  if [[ "${remove_installed_package}" == true ]]; then
    remove_package
  fi
  remove_runtime_state

  # FD 9 remains locked until this process exits; persistent logs and forensic transactions are retained.
  /usr/bin/logger -t usb.guardian "runtime state removed; persistent configuration and logs retained at ${LOG_DIR}" 2>/dev/null || true
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  uninstall_main "$@"
fi
